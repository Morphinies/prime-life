{
  "name": "frontend",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "author": "morphinies",
  "scripts": {
    "build": "react-router build",
    "prebuild__commented": "npm run gen:antd-css",
    "dev": "react-router dev",
    "predev__commented": "npm run gen:antd-css",
    "start": "react-router-serve ./build/server/index.js",
    "typecheck": "react-router typegen && tsc",
    "deploy": "npm run build && npm run start",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "gen:antd-css": "tsx scripts/genAntdCss.tsx"
  },
  "dependencies": {
    "@ant-design/cssinjs": "^2.1.2",
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@react-router/node": "^7.13.2",
    "@react-router/serve": "^7.13.2",
    "@reduxjs/toolkit": "^2.11.2",
    "antd": "^6.3.3",
    "dayjs": "^1.11.20",
    "isbot": "^5",
    "lodash.isequal": "^4.5.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-redux": "^9.2.0",
    "react-router": "^7.13.2",
    "reset-css": "^5.0.2",
    "zod": "^4.3.6"
